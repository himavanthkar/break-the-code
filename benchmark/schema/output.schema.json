{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ECVEBench AgentOutput",
  "type": "object",
  "required": [
    "task_id",
    "difficulty",
    "vulnerable",
    "confidence",
    "vuln_class",
    "locations",
    "reason"
  ],
  "additionalProperties": false,
  "properties": {
    "task_id": {
      "type": "string",
      "description": "GHSA-level task identifier. Must match the task being evaluated."
    },
    "difficulty": {
      "type": "string",
      "enum": ["L0", "L1", "L2", "L3"],
      "description": "Difficulty level the agent ran at. Must match the difficulty of the agent input."
    },
    "vulnerable": {
      "type": "boolean"
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "vuln_class": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "string",
          "enum": [
            "command-injection",
            "sql-injection",
            "xss",
            "buffer-overflow",
            "use-after-free",
            "path-traversal",
            "auth-bypass",
            "xxe",
            "insecure-deserialization",
            "crypto-weakness",
            "race-condition",
            "integer-overflow",
            "null-deref"
          ]
        }
      ]
    },
    "locations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file", "function"],
        "additionalProperties": false,
        "properties": {
          "file": {
            "type": "string"
          },
          "function": {
            "oneOf": [{ "type": "null" }, { "type": "string" }]
          }
        }
      }
    },
    "reason": {
      "oneOf": [{ "type": "null" }, { "type": "string" }],
      "description": "Unscored. Agent explanation of the vulnerability."
    }
  }
}
