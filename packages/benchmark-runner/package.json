{
  "name": "@codebreaker/benchmark-runner",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "benchmark-runner": "./src/cli.ts"
  },
  "exports": {
    "./loaders": {
      "types": "./src/loaders.ts",
      "default": "./src/loaders.ts"
    },
    "./api-client": {
      "types": "./src/api-client.ts",
      "default": "./src/api-client.ts"
    },
    "./schemas": {
      "types": "./src/schemas.ts",
      "default": "./src/schemas.ts"
    },
    "./session-config": {
      "types": "./src/session-config.ts",
      "default": "./src/session-config.ts"
    },
    "./agent-core/direct-runner": {
      "types": "./src/agent-core/direct-runner.ts",
      "default": "./src/agent-core/direct-runner.ts"
    },
    "./agent-core/model": {
      "types": "./src/agent-core/model.ts",
      "default": "./src/agent-core/model.ts"
    },
    "./agent-core/output": {
      "types": "./src/agent-core/output.ts",
      "default": "./src/agent-core/output.ts"
    },
    "./agent-core/prompts": {
      "types": "./src/agent-core/prompts.ts",
      "default": "./src/agent-core/prompts.ts"
    },
    "./agent-core/tools": {
      "types": "./src/agent-core/tools.ts",
      "default": "./src/agent-core/tools.ts"
    }
  },
  "scripts": {
    "benchmark": "node --experimental-strip-types src/cli.ts",
    "typecheck": "tsc --noEmit",
    "validate:fixtures": "node --experimental-strip-types src/validate-fixtures.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.71",
    "@ai-sdk/google": "3.0.64",
    "@ai-sdk/openai": "3.0.53",
    "@codebreaker/shared": "workspace:*",
    "ai": "6.0.168",
    "ai-gateway-provider": "3.1.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.6.0"
  }
}
